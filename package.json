{
  "name": "hackdesk",
  "productName": "HackDesk",
  "description": "📝 A hackable HackMD desktop application",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "electron/dist/main.cjs",
  "engines": {
    "node": ">=20.19",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "frontend:dev": "vite",
    "frontend:build": "tsc -p tsconfig.app.json && vite build",
    "frontend:preview": "vite preview",
    "icons:electron": "node scripts/electron-icons.js",
    "dev:electron": "node scripts/electron-dev.js",
    "build:electron": "node scripts/electron-build.js && vite build",
    "package:electron": "pnpm run icons:electron && pnpm run build:electron && electron-builder",
    "check:electron": "oxlint electron scripts src && pnpm run test:js && pnpm run build:electron",
    "lint:ts:check": "oxlint .",
    "lint:ts": "oxlint --fix .",
    "check:deps": "knip",
    "lint:rs": "cd src-tauri && cargo fmt && cargo clippy --fix --allow-dirty --allow-staged && cd -",
    "lint:cargo": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "check": "pnpm run lint:ts:check && pnpm run check:deps && pnpm run lint:cargo",
    "check:ci": "pnpm run version:check && pnpm run check && pnpm run test && pnpm run build:electron",
    "version:check": "node scripts/check-version.js",
    "contract:hackmd": "node scripts/hackmd-openapi-verify.js",
    "contract:hackmd:live": "node scripts/hackmd-openapi-verify.js --live",
    "sync:version": "node scripts/sync-version.js",
    "test": "pnpm run test:rust && pnpm run test:js",
    "test:js": "vitest run electron src",
    "test:rust": "cd src-tauri && cargo test",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "release": "node scripts/release.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "Michael Wang <michael19920327@gmail.com> (https://github.com/EastSun5566)",
  "repository": {
    "type": "git",
    "url": "https://github.com/EastSun5566/hackdesk"
  },
  "license": "AGPL-3.0",
  "build": {
    "appId": "me.eastsun.hackdesk",
    "productName": "HackDesk",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "electron/dist/**",
      "dist/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "assets/icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-context-menu": "^2.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tanstack/react-query": "^5.90.10",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-fs": "^2.4.4",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dompurify": "^3.4.11",
    "fuse.js": "^7.1.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-html5-embed": "^1.0.0",
    "markdown-it-image-figures": "^2.1.1",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-ruby": "^1.1.2",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-toc-done-right": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^6.30.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@tauri-apps/cli": "^2.9.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "4.1.9",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.0",
    "jsdom": "^27.4.0",
    "knip": "^6.17.1",
    "lint-staged": "^15.5.2",
    "oxlint": "^1.70.0",
    "postcss": "^8.5.6",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitepress": "^1.6.4",
    "vitest": "4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": "oxlint --fix",
    "*.rs": "pnpm run lint:rs"
  }
}
