{
  "name": "hackdesk",
  "productName": "HackDesk",
  "description": "📝 A hackable HackMD desktop application",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "packageManager": "pnpm@11.13.0",
  "main": "electron/dist/main.cjs",
  "engines": {
    "node": "24.x",
    "pnpm": "11.13.0"
  },
  "scripts": {
    "dev": "node scripts/electron-dev.ts",
    "build": "node scripts/electron-build.ts && vite build",
    "preview": "vite preview",
    "package": "pnpm run build && electron-builder",
    "package:check": "pnpm run build && electron-builder --dir --publish never",
    "typecheck": "pnpm run typecheck:app && pnpm run typecheck:node && pnpm run typecheck:electron",
    "typecheck:app": "tsgo -p tsconfig.app.json --noEmit",
    "typecheck:node": "tsgo -p tsconfig.node.json --noEmit",
    "typecheck:electron": "tsgo -p tsconfig.electron.json --noEmit",
    "audit:prod": "pnpm audit --prod --audit-level high",
    "lint:ts": "oxlint .",
    "lint:ts:fix": "oxlint --fix .",
    "check:deps": "knip",
    "check:actions": "github-actionlint",
    "check": "pnpm run typecheck && pnpm run lint:ts && pnpm run check:deps && pnpm run check:actions && pnpm run contract:hackmd && pnpm run test && pnpm run build",
    "check:ci": "pnpm run version:check && pnpm run check",
    "version:check": "node scripts/check-version.ts",
    "contract:hackmd": "node scripts/hackmd-openapi-verify.ts",
    "contract:hackmd:live": "node scripts/hackmd-openapi-verify.ts --live",
    "test": "vitest run electron src docs/.vitepress",
    "test:smoke": "pnpm run build && playwright test --config electron/playwright.config.ts",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "release": "pnpm run build && electron-builder --publish always",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "author": "Michael Wang <hi@eastsun.me> (https://github.com/EastSun5566)",
  "repository": {
    "type": "git",
    "url": "https://github.com/EastSun5566/hackdesk"
  },
  "license": "AGPL-3.0-only",
  "build": {
    "appId": "me.eastsun.hackdesk",
    "productName": "HackDesk",
    "directories": {
      "buildResources": "build",
      "output": "release/electron"
    },
    "files": [
      "electron/dist/**",
      "dist/**",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "EastSun5566",
        "repo": "hackdesk",
        "releaseType": "release"
      }
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "assets/icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "category": "Office",
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-emacs": "6.1.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@tanstack/react-query": "^5.90.10",
    "beautiful-mermaid": "^1.1.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror-helix": "^0.5.7",
    "codemirror-kakoune": "0.2.5",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.8.9",
    "fuse.js": "^7.5.0",
    "gemoji": "^8.1.0",
    "inline-attacher": "^0.1.1",
    "katex": "0.17.0",
    "lucide-react": "^1.17.0",
    "papaparse": "^5.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.2",
    "react-router-dom": "^6.30.2",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.13.2",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@typescript/native-preview": "^7.0.0-dev.20260619.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.9",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "github-actionlint": "^1.7.12",
    "jsdom": "^27.4.0",
    "knip": "^6.17.1",
    "lint-staged": "^15.5.2",
    "oxlint": "^1.70.0",
    "oxlint-plugin-react-doctor": "^0.5.8",
    "oxlint-tsgolint": "^0.22.1",
    "postcss": "^8.5.6",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.17",
    "vite": "^7.3.6",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  }
}
